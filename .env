# VoiceKey Environment Variables
# ─────────────────────────────────────────────────────────────
# Keep this file PRIVATE — never commit it to Git
# Add .env to your .gitignore file
# ─────────────────────────────────────────────────────────────

# Flask session secret — change this to any long random string
SECRET_KEY=change-this-to-a-long-random-string-before-deploying

# Admin user — must match a registered username exactly
# Only this user's voice can unlock the admin panel
ADMIN_USER=harikaran

# MongoDB connection string
# Local:  mongodb://localhost:27017/voicekey
# Atlas:  mongodb+srv://username:password@cluster.mongodb.net/voicekey
MONGO_URI=mongodb://localhost:27017/voicekey

# ── Email (SMTP) — login notification ─────────────────────────────────────────
# Gmail: enable 2FA → Google Account → Security → App Passwords → generate one
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=voiceaccess123@gmail.com
SMTP_PASS=bhktpgeelklbjbdh
SMTP_FROM=VoiceAccess <voiceaccess123@gmail.com>
# ── Google Gemini API (Call Analysis — free) ─────────────────────────────────
GOOGLE_API_KEY=AIzaSyDP5UUaY2gqMixXwdCFcqoQxYqfXf9x64Y